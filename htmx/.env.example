# ── HTMX Risk Dashboard — Environment Configuration Reference ────────
#
# This file documents every HTMX_* knob.  Copy to .env and customise.
# Values shown are the "balanced" profile defaults (today's behavior).
#
# HTMX_CACHE_MODE selects a baseline profile.  Any individual HTMX_*
# variable set in the environment overrides the corresponding profile value.

# ── UI visibility toggles ──
# Show/hide the Refresh button in the header bar (1=show, 0=hide).
SHOW_REFRESH_BUTTON=1
# Show/hide the Asset filter dropdown (applies to pages that enable it).
SHOW_ASSET_FILTER=1
# Show/hide the Price Basis dropdown (applies to pages that enable it).
SHOW_PRICE_BASIS=1
# Navigation layout mode: 0=topbar View dropdown, 1=fixed left sidebar nav.
NAV_LAYOUT_SIDEBAR=1
# Default price basis selection: default, invert-orca, invert-ray, invert-both
DEFAULT_PRICE_BASIS=default

# API host used by server-side proxy calls from HTMX service.
API_BASE_URL=http://localhost:8001
# Base URL embedded into browser widget endpoints.
# Leave blank for same-origin proxy mode (recommended).
BROWSER_API_BASE_URL=
# Root route redirect target page slug.
DEFAULT_HOME_PAGE_SLUG=global-ecosystem

# ── Lookback window options ──
# Comma-separated subset of: 1h,4h,6h,24h,7d,30d,90d
# Omit or leave blank to show all options.
LAST_WINDOW_OPTIONS=1h,4h,6h,24h,7d,30d,90d
# Which option is selected by default (must be in the list above).
DEFAULT_LAST_WINDOW=7d

# ── Cache mode (conservative | balanced | aggressive) ──
# conservative = freshness-first, no speculation (frequent refresh, no preload)
# balanced     = today's exact behavior (default, strict no-op)
# aggressive   = speed-first, accept staleness (all new features enabled)
HTMX_CACHE_MODE=balanced

# Canonical dashboard refresh cadence (seconds). This single control
# seeds UI poll intervals and API cache/prewarm defaults unless explicitly
# overridden by service-specific env vars.
DASH_REFRESH_INTERVAL_SECONDS=30

# ── Warmup settings ──
# Master switch for all warmup activity.
HTMX_WARMUP_ENABLED=1
# Total time budget (seconds) the warmup cycle may run.
HTMX_WARMUP_BUDGET_SECONDS=30
# Max total warmup jobs across all pages.
HTMX_WARMUP_MAX_JOBS=30
# Max concurrent warmup API requests.
HTMX_WARMUP_CONCURRENCY=3
# Max widgets warmed per page.
HTMX_WARMUP_WIDGETS_PER_PAGE=10
# When true, warmup POST requests include_payloads=true and the
# response payloads are hydrated directly into the client widget cache,
# eliminating per-widget round-trips for warmed pages.
# conservative=0, balanced=1, aggressive=1
# HTMX_WARMUP_RETURN_PAYLOADS=1

# ── Cache TTLs and age limits ──
# Max age for critical widget cache entries (ms).
HTMX_CRITICAL_CACHE_MAX_AGE_MS=60000
# Max age for default (non-critical) widget cache entries (ms).
HTMX_DEFAULT_CACHE_MAX_AGE_MS=300000
# TTL for soft-nav shell cache entries (ms).  Default 60 min.
HTMX_SOFT_NAV_SHELL_CACHE_TTL_MS=3600000
# Max entries in the widget response cache (LRU).
HTMX_WIDGET_RESPONSE_CACHE_MAX_ENTRIES=100
# Max signatures retained per widget id before oldest are evicted.
HTMX_WIDGET_RESPONSE_CACHE_PER_WIDGET_LIMIT=8
# Max entries in the soft-nav shell cache (LRU).
HTMX_SOFT_NAV_SHELL_CACHE_MAX_ENTRIES=5
# Persist cache max serialized size (bytes) for localStorage snapshot.
HTMX_PERSIST_CACHE_MAX_BYTES=2097152
# Persist cache combined entry cap (shells + widgets).
HTMX_PERSIST_CACHE_MAX_ENTRIES=220
# Persist cache widget entry cap (applied before byte-size trim).
HTMX_PERSIST_CACHE_WIDGET_MAX_ENTRIES=180

# ── Navigation tuning ──
# Delay (ms) before background shell refresh after a cache-hit soft navigation.
HTMX_SOFT_NAV_SHELL_REFRESH_DELAY_MS=3000
# Time (ms) an offscreen widget must be unseen before its poll is suppressed.
HTMX_VIEWPORT_POLL_STALE_MS=45000

# ── Refresh intervals ──
# Per-kind widget refresh intervals (seconds).
# If unset, these default to DASH_REFRESH_INTERVAL_SECONDS.
HTMX_REFRESH_KPI_SECONDS=30
HTMX_REFRESH_CHART_SECONDS=30
HTMX_REFRESH_TABLE_SECONDS=30

# ── Feature flags (varies by cache mode profile) ──
# Intent-based prefetch: prefetch adjacent page shells on select focus/change.
HTMX_HOVER_PREFETCH_ENABLED=0
# Parallel shell prefetch during warmup (vs sequential).
HTMX_PARALLEL_SHELL_PREFETCH=0
# Concurrency limit for parallel shell prefetch.
HTMX_SHELL_PREFETCH_CONCURRENCY=1
# Re-trigger warmup after filter/context changes.
HTMX_REWARMUP_ON_FILTER_CHANGE=0
# Idle delay (ms) before re-warmup fires after a filter change.
HTMX_REWARMUP_IDLE_DELAY_MS=0
# Batched above-fold reveal: hold visible widgets and render together.
HTMX_BATCHED_REVEAL_ENABLED=0
# Timeout (ms) for batched reveal quorum.  0 = disabled.
HTMX_BATCHED_REVEAL_TIMEOUT_MS=0
# Max concurrent widget requests.  0 = unlimited (today's behavior).
HTMX_MAX_CONCURRENT_WIDGET_REQUESTS=0
# Suppress first-load for offscreen widgets, load lazily on scroll.
HTMX_OFFSCREEN_PAUSE_ENABLED=0
# Minimum skeleton display time (ms) to prevent flash-of-skeleton.
HTMX_SKELETON_MIN_DISPLAY_MS=0
# Adaptive dial-down: self-suppress prefetch when hit-rate is low.
HTMX_ADAPTIVE_DIALDOWN_ENABLED=0
# Hit-rate threshold below which dial-down triggers (0.0-1.0).
HTMX_ADAPTIVE_DIALDOWN_HIT_THRESHOLD=0

# ── Persistence (optional follow-up) ──
# Persist shell/widget cache to localStorage across page reloads.
# Bounded to ~2MB, LRU eviction, strict TTL.
HTMX_PERSIST_CACHE_ENABLED=1

# ── Diagnostics ──
# Log perf counters to browser console every 60s (0/1).
HTMX_CLIENT_PERF_METRICS=0

# ── HTMX proxy and health/meta cache controls ──
HTMX_API_PROXY_TIMEOUT_SECONDS=60
HTMX_HEALTH_STATUS_TIMEOUT_SECONDS=3
HTMX_HEALTH_STATUS_CACHE_TTL_SECONDS=5
HTMX_META_CACHE_TTL_SECONDS=300
HTMX_HEALTH_TABLE_BASE_DELAY_SECONDS=0.08
HTMX_HEALTH_TABLE_STEP_DELAY_SECONDS=0.12
HTMX_HEALTH_CHART_BASE_DELAY_SECONDS=0.35
HTMX_HEALTH_CHART_STEP_DELAY_SECONDS=0.18

# ── Cross-service tuning commonly set in shared container env ──
# These are consumed by the API service when both services share env
# (e.g., root Dockerfile + start-prod.sh).
API_CACHE_MODE=speed
API_TELEMETRY_ENABLED=0
API_PREWARM_GLOBAL_HOTSPOTS_ENABLED=1
GE_HOTSPOT_WIDGET_TTL_SECONDS=180

# ── Security ──
# Leave blank when API is private and accessed via HTMX same-origin proxy.
CORS_ALLOWED_ORIGINS=
