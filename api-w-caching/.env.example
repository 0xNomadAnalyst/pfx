# ── API Cache Mode ────────────────────────────────────────────────────
# Selects a profile baseline.  Individual API_* vars below override the
# profile defaults.  Profiles: fresh | balanced (default) | speed
#
#   fresh     → low TTL, no jitter, conservative SWR (pairs with HTMX conservative)
#   balanced  → moderate TTL, 10% jitter, 4 SWR workers (pairs with HTMX balanced)
#   speed     → high TTL, 15% jitter, 6 SWR workers (pairs with HTMX aggressive)
#
# API_CACHE_MODE=balanced

# ── Core cache parameters ────────────────────────────────────────────
# API_CACHE_TTL_SECONDS=30          # fresh=30, balanced=30, speed=120
# API_CACHE_SWR_SECONDS=15          # fresh=5,  balanced=15, speed=30
# API_CACHE_MAX_ENTRIES=256          # fresh=256, balanced=256, speed=512
# API_CACHE_TTL_JITTER_PCT=10       # fresh=0, balanced=10, speed=15
#                                    #   ±N% random jitter on TTL to prevent
#                                    #   synchronized expiry after warmup bursts.
#                                    #   Effective TTL floor is 1s.
# API_CACHE_SWR_WORKERS=4           # fresh=2, balanced=4, speed=6
#                                    #   Max threads for stale-while-revalidate
#                                    #   background refreshes.

# ── Diagnostics ──────────────────────────────────────────────────────
# API_CACHE_STATS_ENABLED=1         # fresh=0, balanced=1, speed=0
#                                    #   Enables GET /api/v1/cache-stats endpoint.
# API_CACHE_LOG_SWR=0               # Log stale-while-revalidate events.
# API_LOG_SLOW_WIDGETS=0            # Log widgets exceeding threshold.
# API_SLOW_WIDGET_THRESHOLD_MS=150

# ── Key normalization ────────────────────────────────────────────────
# API_PIPELINE_LOCKED=0             # When 1, health/exponent cache keys
#                                    #   omit the pipeline prefix, collapsing
#                                    #   redundant entries in single-pipeline
#                                    #   deployments.

# ── TTL alignment with client cache modes ────────────────────────────
# The server TTL should outlive the client's critical cache max-age so
# that re-warmup cycles hit server cache rather than cold DB queries:
#
#   HTMX conservative (critical 15s)  → API fresh   (TTL 30s)   ✓
#   HTMX balanced     (critical 30s)  → API balanced (TTL 30s)   ✓
#   HTMX aggressive   (critical 120s) → API speed   (TTL 120s)  ✓
#
# If running HTMX_CACHE_MODE=aggressive, set API_CACHE_MODE=speed
# (or API_CACHE_TTL_SECONDS=120) to prevent premature server-side expiry.

# ── Database ─────────────────────────────────────────────────────────
# DB_HOST=localhost
# DB_PORT=5432
# DB_NAME=risk_dash
# DB_USER=
# DB_PASSWORD=
# DB_POOL_PREWARM=1

# ── Prewarm (startup) ───────────────────────────────────────────────
# API_PREWARM_ENABLED=1
# API_PREWARM_MAX_SECONDS=30
# API_PREWARM_WINDOWS=1h,24h,7d
# API_PREWARM_ROWS=20,120
# API_PREWARM_DEX_ENABLED=1
# API_PREWARM_DEX_WINDOWS=24h
# API_PREWARM_EXPONENT_ENABLED=1
# API_PREWARM_EXPONENT_WINDOWS=24h
# API_PREWARM_EXPONENT_FIRST=1
# API_PREWARM_HEALTH_ENABLED=1
# API_PREWARM_HEALTH_WINDOWS=24h,7d
# API_PREWARM_GLOBAL_ENABLED=1
# API_PREWARM_GLOBAL_WINDOWS=24h,7d
